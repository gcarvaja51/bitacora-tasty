# ─── TastyTrade Credenciales ───────────────────────────────
# Tu email de login en TastyTrade
TT_USERNAME=tu_email@ejemplo.com

# Remember Token (se obtiene al hacer login con remember-me: true)
# Válido por ~30 días. Si expira, haz login manual y obtén uno nuevo.
TT_REMEMBER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de cuenta (lo ves en TastyTrade → Account)
TT_ACCOUNT_NUMBER=5WZ83584

# ─── Tradier (sandbox) ──────────────────────────────────────
# Access token del sandbox de Tradier (developer.tradier.com)
TRADIER_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de cuenta sandbox
TRADIER_ACCOUNT_NUMBER=xxxxxxxxxxx

# Base URL — sandbox por defecto, cambiar a https://api.tradier.com/v1 para produccion
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# ─── Servidor ───────────────────────────────────────────────
# Railway lo setea automáticamente. Para local usa 3000.
PORT=3000

# ─── Cómo obtener el Remember Token ────────────────────────
# Opción 1 (curl):
#   curl -X POST https://api.tastytrade.com/sessions \
#     -H "Content-Type: application/json" \
#     -d '{"login":"tu_email","password":"tu_pass","remember-me":true}'
#   → copia el campo "remember-token" de la respuesta
#
# Opción 2: El bot de Telegram ya tiene el token guardado en
#   las variables de Railway del proyecto anterior.
